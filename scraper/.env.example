# IRL Scraper Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key — enables AI features:
#   - EventVerifierAgent: verifies events are real, removes hallucinations
#   - EditorialAgent: generates quality scores and editor picks
#   - LocationVerifierAgent: validates venue coordinates
#
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Apify API token — enables Dice.fm event scraping via Apify actor
# Get your token from: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...
