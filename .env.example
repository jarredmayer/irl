# IRL App Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────
# ANTHROPIC API (for AI agents)
# ─────────────────────────────────────────
# Server-side usage (scraper, backend)
ANTHROPIC_API_KEY=

# Client-side usage (editorial agent in browser)
# Note: This is exposed to the client - only use for non-sensitive operations
VITE_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────
# IMAGE GENERATION (optional, pick one)
# ─────────────────────────────────────────
# Replicate API - for FLUX image generation
# Get your key from: https://replicate.com/account/api-tokens
VITE_REPLICATE_API_KEY=

# Fal.ai API - alternative image generation
# Get your key from: https://fal.ai/dashboard/keys
VITE_FAL_API_KEY=

# ─────────────────────────────────────────
# WEATHER DATA (for editorial agent)
# ─────────────────────────────────────────
# OpenWeather API - for forecast data in Yourcast
# Get your key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────
# SCRAPER KEYS (see scraper/.env.example)
# ─────────────────────────────────────────
# APIFY_TOKEN=apify_api_...
