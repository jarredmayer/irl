# IRL App Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────
# ANTHROPIC API (for AI agents)
# ─────────────────────────────────────────
# Server-side usage (scraper, backend)
ANTHROPIC_API_KEY=

# Client-side usage (editorial agent in browser)
# Note: This is exposed to the client - only use for non-sensitive operations
VITE_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────
# IMAGE APIS (free tiers, no watermarks)
# ─────────────────────────────────────────
# Pexels API - 200 req/hr, high quality, no watermark
# Get your key from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=

# Unsplash API - 50 req/hr, requires attribution
# Get your key from: https://unsplash.com/developers
VITE_UNSPLASH_ACCESS_KEY=

# ─────────────────────────────────────────
# AI IMAGE GENERATION (optional, advanced)
# ─────────────────────────────────────────
# Fal.ai API - optional AI image generation
# Get your key from: https://fal.ai/dashboard/keys
VITE_FAL_API_KEY=

# ─────────────────────────────────────────
# WEATHER DATA (for editorial agent)
# ─────────────────────────────────────────
# OpenWeather API - for forecast data in Yourcast
# Get your key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────
# SCRAPER KEYS (see scraper/.env.example)
# ─────────────────────────────────────────
# APIFY_TOKEN=apify_api_...
